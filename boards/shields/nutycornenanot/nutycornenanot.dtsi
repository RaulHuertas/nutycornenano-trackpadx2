#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/input_transform.h>
#include "nutycornenanot-layouts.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {

	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <10>;
		rows = <4>;
		map = <
                RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)  RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
                RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)  RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
                RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)  RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
                RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)  RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9)
		>;
	};

    kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
	};

    xiao_i2c {
        status = "okay";
        clock-frequency = <I2C_BITRATE_STANDARD>;
        trackpad: glidepoint@2a { 
            compatible = "cirque,pinnacle";
            //status = "okay";
            status = "disabled";
            reg = <0x2a>;
            dr-gpios = <&gpio1 3 (GPIO_ACTIVE_HIGH)>;
            sensitivity = "2x";
            sleep;
            x-invert;
            no-secondary-tap;
            //y-invert;
            //rotate-90;
        };
    };

    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;
        glidepoint_split: glidepoint_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
        };
    };
    glidepoint_rh_listener: glidepoint_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&glidepoint_split>;
    };
    glidepoint_lh_listener: glidepoint_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&trackpad>;
    };
};

&physical_layout0 {
    kscan = <&kscan0>;
    transform = <&default_transform>;
};

&usbd {
	status = "okay";
};

